cat("\nTóm tắt mô hình:\n")
summary_model <- summary(model)
print(summary_model)
# Xem hệ số hồi quy và Odds Ratio
coef_df <- data.frame(
feature = names(coef(model)),
coefficients = coef(model),
odds_ratio = exp(coef(model)),
p_value = summary_model$coefficients[,4]
)
print(coef_df)
# Bước 6: Dự đoán trên tập kiểm tra
# Dự đoán xác suất
probabilities <- predict(model, newdata=test_data, type="response")
# Đặt ngưỡng 0.5 để phân loại
predicted_classes <- ifelse(probabilities > 0.5, "Potable", "Not_Potable")
predicted_classes <- factor(predicted_classes, levels=c("Not_Potable", "Potable"))
# Bước 7: Đánh giá mô hình
# Tạo ma trận nhầm lẫn (Confusion Matrix)
conf_matrix <- confusionMatrix(predicted_classes, test_data$Potability)
print(conf_matrix$table)
cat("\nCác chỉ số đánh giá mô hình:\n")
cat("Độ chính xác (Accuracy):", round(conf_matrix$overall["Accuracy"], 4), "\n")
cat("Độ nhạy (Sensitivity):", round(conf_matrix$byClass["Sensitivity"], 4), "\n")
cat("Độ đặc hiệu (Specificity):", round(conf_matrix$byClass["Specificity"], 4), "\n")
cat("Chỉ số F1:", round(conf_matrix$byClass["F1"], 4), "\n")
# Vẽ đường cong ROC
roc_obj <- roc(test_data$Potability, probabilities)
auc_value <- auc(roc_obj)
cat("Diện tích dưới đường cong ROC (AUC):", round(auc_value, 4), "\n")
plot(roc_obj, main="Đường cong ROC - Chất lượng nước", col="blue", lwd=2)
abline(a=0, b=1, lty=2, col="red") # Đường chéo tham chiếu
if(!require(ggplot2)) install.packages("ggplot2")
library(ggplot2)
# conf_matrix$table chứa bảng dữ liệu thô
cm_frame <- as.data.frame(conf_matrix$table)
# Bước 3: Đặt lại tên cột để dễ sử dụng trong ggplot2
# Cột 1: Lớp dự đoán (Prediction)
# Cột 2: Lớp thực tế (Reference)
# Cột 3: Số lượng mẫu (Freq)
names(cm_frame) <- c("Prediction", "Reference", "Freq")
# Bước 4: Vẽ đồ thị bằng ggplot2
ggplot(data = cm_frame, aes(x = Reference, y = Prediction, fill = Freq)) +
# Vẽ các ô vuông (tile)
geom_tile(color = "white", lwd = 1) +
# Hiển thị số lượng mẫu thô (Freq) ở giữa mỗi ô
geom_text(aes(label = Freq), vjust = .5, fontface = "bold", size = 8, color = "white") +
# Thiết lập màu sắc (Gradient): Màu xanh lá đậm cho số lượng lớn
scale_fill_gradient(low = "#e3f2fd", high = "#1565c0") +
# Thiết lập tiêu đề và nhãn trục
labs(title = "Ma trận nhầm lẫn - Dự đoán chất lượng nước",
subtitle = "(Mô hình Hồi quy Logistic)",
x = "Lớp Thực Tế (True Class)",
y = "Lớp Dự Đoán (Predicted Class)",
fill = "Số lượng") +
# Tùy chỉnh giao diện (Theme) cho đẹp và rõ ràng
theme_minimal() +
theme(
plot.title = element_text(size = 18, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 12, hjust = 0.5),
axis.title = element_text(size = 14),
axis.text = element_text(size = 12, face = "bold"),
legend.position = "right",
panel.grid.major = element_blank(), # Ẩn lưới nền
panel.grid.minor = element_blank()
)
# 1. Tải thư viện cần thiết
library(ggplot2)
library(dplyr)
# 2. Chuyển đổi dữ liệu từ kết quả của caret thành Data Frame
