# Hiển thị số lượng mẫu (Freq) ở giữa ô
geom_text(aes(label = Freq), color = "white", size = 8, fontface = "bold") +
# Hiển thị tỷ lệ phần trăm nhỏ ở phía dưới số lượng (tùy chọn)
geom_text(aes(label = sprintf("(%.1f%%)", Prop*100)),
color = "white", size = 4, vjust = 3) +
# Tùy chỉnh màu sắc (Xanh dương đậm cho số lượng lớn)
scale_fill_gradient(low = "#d1e9ff", high = "#004085") +
# Thêm nhãn và tiêu đề
labs(
title = "Confusion matrix: Predicting the potability of waterc",
subtitle = "Logistic Regression Model",
x = "Actual",
y = "Predicted",
fill = "Quantity"
) +
# Tùy chỉnh giao diện
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 12, hjust = 0.5),
axis.text = element_text(size = 12, face = "bold"),
axis.title = element_text(size = 13),
legend.position = "right"
)
# TÓM TẮT BÀI TOÁN:
# Bài thực hành này sử dụng bộ dữ liệu water_potability để dự đoán liệu một mẫu nước có uống được hay không
# dựa trên các chỉ số hóa học và vật lý khác nhau. Chúng ta sẽ sử dụng mô hình hồi quy logistic để
# xây dựng bộ phân loại nhị phân, đánh giá hiệu suất của mô hình và trực quan hóa kết quả.
# Biến mục tiêu: Potability (0 = không uống được, 1 = uống được)
library(tidyverse)
library(caTools)
library(caret)
library(pROC)
library(readr)
if(!require(ggplot2)) install.packages("ggplot2")
library(ggplot2)
water_potability <- read_csv("D:/R/labs/data/water_potability.csv")
dataset_name <- "Water Potability Dataset"
View(water_potability)
str(water_potability)
summary(water_potability)
# Kiểm tra các giá trị thiếu (NA)
colSums(is.na(water_potability))
water_potability <- water_potability %>%
mutate(across(everything(), ~replace_na(., median(., na.rm = TRUE))))
# Chuyển đổi biến mục tiêu thành factor
water_potability$Potability <- as.factor(water_potability$Potability)
levels(water_potability$Potability) <- c("Not_Potable", "Potable")
# Thông tin cơ bản
cat("Thông tin về tập dữ liệu:", dataset_name, "\n")
cat("Số mẫu:", nrow(water_potability), "\n")
cat("Số đặc trưng:", ncol(water_potability)-1, "\n\n")
# Hiển thị cấu trúc và thống kê
str(water_potability)
summary(water_potability)
# Kiểm tra phân phối biến mục tiêu
cat("\nPhân phối biến mục tiêu (Khả năng uống được):\n")
print(table(water_potability$Potability))
print(prop.table(table(water_potability$Potability)) * 100)
# Bước 3: Phân chia dữ liệu (70% Train, 30% Test)
set.seed(42)
train_indices <- createDataPartition(water_potability$Potability, p=0.7, list = FALSE)
train_data <- water_potability[train_indices, ]
test_data  <- water_potability[-train_indices, ]
cat("\nKích thước tập huấn luyện:", dim(train_data))
cat("\nKích thước tập kiểm tra:", dim(test_data))
# Bước 4: Xây dựng mô hình hồi quy logistic
# Dự đoán Potability dựa trên tất cả các chỉ số (.)
model <- glm(Potability ~ .,
data = train_data,
family = binomial(link="logit"))
# Bước 5: Kiểm tra thông số mô hình
cat("\nTóm tắt mô hình:\n")
summary_model <- summary(model)
print(summary_model)
# Xem hệ số hồi quy và Odds Ratio
coef_df <- data.frame(
feature = names(coef(model)),
coefficients = coef(model),
odds_ratio = exp(coef(model)),
p_value = summary_model$coefficients[,4]
)
print(coef_df)
# Bước 6: Dự đoán trên tập kiểm tra
# Dự đoán xác suất
probabilities <- predict(model, newdata=test_data, type="response")
# Đặt ngưỡng 0.5 để phân loại
predicted_classes <- ifelse(probabilities > 0.5, "Potable", "Not_Potable")
predicted_classes <- factor(predicted_classes, levels=c("Not_Potable", "Potable"))
# Bước 7: Đánh giá mô hình
# Tạo ma trận nhầm lẫn (Confusion Matrix)
conf_matrix <- confusionMatrix(predicted_classes, test_data$Potability)
print(conf_matrix$table)
cat("\nCác chỉ số đánh giá mô hình:\n")
cat("Độ chính xác (Accuracy):", round(conf_matrix$overall["Accuracy"], 4), "\n")
cat("Độ nhạy (Sensitivity):", round(conf_matrix$byClass["Sensitivity"], 4), "\n")
cat("Độ đặc hiệu (Specificity):", round(conf_matrix$byClass["Specificity"], 4), "\n")
cat("Chỉ số F1:", round(conf_matrix$byClass["F1"], 4), "\n")
# Vẽ đường cong ROC
roc_obj <- roc(test_data$Potability, probabilities)
auc_value <- auc(roc_obj)
cat("Diện tích dưới đường cong ROC (AUC):", round(auc_value, 4), "\n")
plot(roc_obj, main="Đường cong ROC - Chất lượng nước", col="blue", lwd=2)
abline(a=0, b=1, lty=2, col="red") # Đường chéo tham chiếu
# 1. Tải thư viện cần thiết
library(ggplot2)
library(dplyr)
# 2. Chuyển đổi dữ liệu từ kết quả của caret thành Data Frame
# Giả sử bạn đã có biến 'conf_matrix' từ bước trước
cm_data <- as.data.frame(conf_matrix$table)
# 3. Tính toán tỷ lệ phần trăm để hiển thị thêm (tùy chọn)
cm_data <- cm_data %>%
group_by(Reference) %>%
mutate(Prop = Freq / sum(Freq))
# 4. Vẽ biểu đồ bằng ggplot2
ggplot(data = cm_data, aes(x = Reference, y = Prediction, fill = Freq)) +
# Vẽ các ô vuông
geom_tile(color = "white", size = 1) +
# Hiển thị số lượng mẫu (Freq) ở giữa ô
geom_text(aes(label = Freq), color = "white", size = 8, fontface = "bold") +
# Hiển thị tỷ lệ phần trăm nhỏ ở phía dưới số lượng (tùy chọn)
geom_text(aes(label = sprintf("(%.1f%%)", Prop*100)),
color = "white", size = 4, vjust = 3) +
# Tùy chỉnh màu sắc (Xanh dương đậm cho số lượng lớn)
scale_fill_gradient(low = "#d1e9ff", high = "#004085") +
# Thêm nhãn và tiêu đề
labs(
title = "Confusion matrix: Predicting the potability of waterc",
subtitle = "Logistic Regression Model",
x = "Actual",
y = "Predicted",
fill = "Quantity"
) +
# Tùy chỉnh giao diện
theme_minimal() +
theme(
plot.title = element_text(size = 16, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 12, hjust = 0.5),
