# 1. Tải thư viện cần thiết
library(ggplot2)
library(dplyr)
# 2. Chuyển đổi dữ liệu từ kết quả của caret thành Data Frame
# Giả sử bạn đã có biến 'conf_matrix' từ bước trước
cm_data <- as.data.frame(conf_matrix$table)
# 3. Tính toán tỷ lệ phần trăm để hiển thị thêm (tùy chọn)
cm_data <- cm_data %>%
group_by(Reference) %>%
mutate(Prop = Freq / sum(Freq))
# 4. Vẽ biểu đồ bằng ggplot2
ggplot(data = cm_data, aes(x = Reference, y = Prediction, fill = Freq)) +
# Vẽ các ô vuông
geom_tile(color = "white", size = 1) +
# Hiển thị số lượng mẫu (Freq) ở giữa ô
geom_text(aes(label = Freq), color = "white", size = 8, fontface = "bold") +
# Hiển thị tỷ lệ phần trăm nhỏ ở phía dưới số lượng (tùy chọn)
geom_text(aes(label = sprintf("(%.1f%%)", Prop*100)),
color = "white", size = 4, vjust = 3) +
# Tùy chỉnh màu sắc (Xanh dương đậm cho số lượng lớn)
